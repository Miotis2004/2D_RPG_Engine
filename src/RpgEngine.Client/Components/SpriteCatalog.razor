@inject EngineCatalog Catalog

<section class="panel">
    <h2>Spritesheet Animation Catalog</h2>
    <p>Define frame dimensions, frame counts, and timing for environment props, characters, NPCs, and mobs.</p>
    <div class="cards">
        @foreach (var actor in Catalog.Actors)
        {
            <article class="card">
                <div class="sprite-preview">@actor.Name[0]</div>
                <h3>@actor.Name</h3>
                <p>@actor.Role</p>
                <small>@actor.Animation.SpriteSheet · @actor.Animation.FrameCount frames · @actor.Animation.FrameDurationMs ms</small>
            </article>
        }
    </div>
</section>
