@page "/"

<PageTitle>2D RPG Engine & Editor</PageTitle>

<section class="hero-panel">
    <div>
        <p class="eyebrow">Blazor tile engine prototype</p>
        <h1>Build maps, author encounters, and test RPG flows in one web editor.</h1>
        <p class="hero-copy">
            A foundation for a browser-based 2D RPG engine with top-down exploration,
            side-view battles, sprite-sheet animation, and classic party management menus.
        </p>
        <div class="hero-actions">
            <a class="btn btn-primary" href="#editor">Open editor mockup</a>
            <a class="btn btn-outline-light" href="#systems">Review systems</a>
        </div>
    </div>
    <div class="hero-card" aria-label="Project status">
        <span class="status-pill">Phase 1</span>
        <h2>Engine vertical slice</h2>
        <ul>
            <li>Tile map scene model</li>
            <li>Sprite-sheet animation plan</li>
            <li>Exploration and combat cameras</li>
            <li>Menu-driven game state</li>
        </ul>
    </div>
</section>

<section id="editor" class="workspace-grid" aria-label="Editor workspace preview">
    <aside class="tool-panel">
        <h2>Editor tools</h2>
        <button class="tool active">Paint terrain</button>
        <button class="tool">Place object</button>
        <button class="tool">Event trigger</button>
        <button class="tool">Collision mask</button>

        <h3>Tileset</h3>
        <div class="tileset" aria-label="Sample tileset swatches">
            @foreach (var tile in Tiles)
            {
                <span class="tile-swatch @tile.CssClass" title="@tile.Name"></span>
            }
        </div>
    </aside>

    <div class="map-stage">
        <div class="stage-toolbar">
            <strong>Top-down world map</strong>
            <span>32px tiles · 20 × 12 viewport</span>
        </div>
        <div class="tile-map" role="img" aria-label="A sample tile based village map with paths, water, trees, and a player marker">
            @for (var row = 0; row < MapRows.Length; row++)
            {
                for (var col = 0; col < MapRows[row].Length; col++)
                {
                    var marker = row == 6 && col == 8 ? "player" : string.Empty;
                    <span class="map-tile @GetTileClass(MapRows[row][col]) @marker"></span>
                }
            }
        </div>
    </div>

    <aside class="inspector-panel">
        <h2>Inspector</h2>
        <dl>
            <dt>Scene</dt>
            <dd>Oakvale Village</dd>
            <dt>Active layer</dt>
            <dd>Ground + events</dd>
            <dt>Selected tile</dt>
            <dd>Grass / walkable</dd>
        </dl>
        <h3>Event script</h3>
        <pre>onInteract:
  showDialog("Welcome!")
  startQuest("lost-signet")</pre>
    </aside>
</section>

<section id="systems" class="systems-grid">
    @foreach (var system in EngineSystems)
    {
        <article class="system-card">
            <span>@system.Icon</span>
            <h2>@system.Title</h2>
            <p>@system.Description</p>
        </article>
    }
</section>

<section class="combat-preview">
    <div>
        <p class="eyebrow">Side-view combat</p>
        <h2>Switch from exploration maps into a dedicated battle stage.</h2>
        <p>
            Combat scenes reserve lanes for party members, enemies, spell effects, turn order,
            and battle menus while reusing the same sprite-sheet animation definitions.
        </p>
    </div>
    <div class="battle-stage" aria-label="Side view battle stage preview">
        <span class="fighter hero-fighter">Knight</span>
        <span class="fighter mage-fighter">Mage</span>
        <span class="fighter slime-fighter">Slime</span>
        <span class="fighter goblin-fighter">Goblin</span>
        <div class="battle-menu">Attack · Item · Spell · Defend</div>
    </div>
</section>

@code {
    private readonly TileSwatch[] Tiles =
    [
        new("Grass", "grass"),
        new("Path", "path"),
        new("Water", "water"),
        new("Forest", "forest"),
        new("Stone", "stone"),
        new("Roof", "roof")
    ];

    private readonly string[] MapRows =
    [
        "fffffgggggggggwwwwww",
        "fgggggggggggggwwwwww",
        "ggggpppppggggggwwwww",
        "ggggpgggpggttggggggg",
        "ggggpgrrpggttggggggg",
        "pppppgrrpgggggggffff",
        "ggggggggppppppggffff",
        "ggtggggggggggpgggggg",
        "ggtgggssssgggpgggggg",
        "ggggggssssgggpgggttg",
        "wwwwwggggggggpgggttg",
        "wwwwwggggggggppppppp"
    ];

    private readonly EngineSystem[] EngineSystems =
    [
        new("🧭", "Exploration engine", "Top-down camera, tile collision, event triggers, interactable props, doors, NPCs, and map transitions."),
        new("⚔️", "Battle engine", "Side-view combat layouts with animated party and enemy battlers, turn flow, commands, effects, and rewards."),
        new("🎞️", "Sprite animation", "Sprite-sheet metadata for idle, walk, attack, cast, hit, and death clips shared by characters and mobs."),
        new("🎒", "Menu systems", "Settings, character sheets, inventory, equipment, spells, quests, saves, and party management screens."),
        new("🧱", "Tile editor", "Layered tile painting, collision overlays, object placement, event scripts, tileset palettes, and scene inspection."),
        new("💾", "Project data", "Structured game definitions ready for JSON persistence, asset references, validation, and eventual import/export tooling.")
    ];

    private static string GetTileClass(char tile) => tile switch
    {
        'p' => "path",
        'w' => "water",
        'f' => "forest",
        't' => "tree",
        's' => "stone",
        'r' => "roof",
        _ => "grass"
    };

    private sealed record TileSwatch(string Name, string CssClass);
    private sealed record EngineSystem(string Icon, string Title, string Description);
}
