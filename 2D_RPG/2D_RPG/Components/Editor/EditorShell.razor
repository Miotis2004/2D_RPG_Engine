@using _2D_RPG.Models
@using _2D_RPG.Services
@inject EditorStateService EditorState
@inject TileMapService TileMap

<PageTitle>@EditorState.CurrentProject.Name - Editor</PageTitle>

<div class="editor-shell">
    <header class="editor-toolbar" aria-label="Editor toolbar">
        <div>
            <p class="eyebrow">Map Authoring</p>
            <h1>@EditorState.CurrentProject.Name</h1>
        </div>
        <div class="toolbar-actions">
            <span class="status-pill @(EditorState.IsDirty ? "dirty" : "clean")">@(EditorState.IsDirty ? "Unsaved changes" : "Clean")</span>
            <button type="button" class="tool" @onclick="Undo" disabled="@(!TileMap.CanUndo)">Undo</button>
            <button type="button" class="tool" @onclick="Redo" disabled="@(!TileMap.CanRedo)">Redo</button>
            <button type="button" class="tool" @onclick="EditorState.MarkClean">Mark clean</button>
        </div>
    </header>

    <section class="workspace-grid authoring-workspace" aria-label="Editor workspace">
        <aside class="tool-panel">
            <h2>Maps</h2>
            @foreach (var map in EditorState.CurrentProject.Maps)
            {
                <button type="button" class="tool @(map.Id == EditorState.ActiveMapId ? "active" : null)" @onclick="() => SelectMap(map.Id)">@map.Name</button>
            }
            <div class="map-actions">
                <button type="button" class="tool" @onclick="CreateMap">New map</button>
                <button type="button" class="tool" @onclick="DuplicateMap">Duplicate</button>
                <button type="button" class="tool" @onclick="RenameMap">Rename</button>
                <button type="button" class="tool" @onclick="ResizeMap">Resize</button>
                <button type="button" class="tool danger" @onclick="DeleteMap" disabled="@(EditorState.CurrentProject.Maps.Count <= 1)">Delete</button>
            </div>

            <TilePalette TileSet="ActiveTileSet" />
        </aside>

        <main class="map-stage" aria-label="Active map viewport">
            <div class="stage-toolbar">
                <strong>@ActiveMap?.Name</strong>
                <span>@ActiveMap?.TileWidth px tiles · @ActiveMap?.Width × @ActiveMap?.Height map · @EditorState.ToolState.ActiveTool</span>
            </div>
            <MapCanvas Map="ActiveMap" TileSet="ActiveTileSet" />
        </main>

        <aside class="inspector-panel">
            <h2>Inspector</h2>
            <label>Map name <input class="inspector-input" value="@ActiveMap?.Name" @onchange="RenameFromInput" /></label>
            <label>Music cue <input class="inspector-input" value="@ActiveMap?.MusicCue" @onchange="UpdateMusic" /></label>
            <h3>Layers</h3>
            @foreach (var layer in ActiveMap?.Layers ?? Enumerable.Empty<MapLayerDefinition>())
            {
                <div class="layer-row @(layer.Id == EditorState.ToolState.ActiveLayerId ? "active" : null)">
                    <button type="button" @onclick="() => EditorState.SetActiveLayer(layer.Id)">@layer.Name</button>
                    <label><input type="checkbox" checked="@layer.IsVisible" @onchange="args => ToggleVisible(layer, args)" /> Visible</label>
                    <label><input type="checkbox" checked="@layer.IsLocked" @onchange="args => ToggleLocked(layer, args)" /> Locked</label>
                </div>
            }
            <dl>
                <dt>Active layer</dt><dd>@EditorState.ToolState.ActiveLayerId</dd>
                <dt>Selected tile</dt><dd>@EditorState.ToolState.SelectedTileId</dd>
                <dt>Music</dt><dd>@ActiveMap?.MusicCue</dd>
            </dl>
        </aside>
    </section>
</div>

@code {
    private MapDefinition? ActiveMap => EditorState.ActiveMap;
    private TileSetDefinition? ActiveTileSet => EditorState.CurrentProject.TileSets.FirstOrDefault(tileSet => tileSet.Id == ActiveMap?.TileSetId);

    private void SelectMap(string mapId)
    {
        EditorState.ActiveMapId = mapId;
        if (EditorState.ActiveMap?.Layers.FirstOrDefault() is { } layer)
        {
            EditorState.ToolState.ActiveLayerId = layer.Id;
        }
    }
    private void Undo() { if (TileMap.Undo(EditorState.CurrentProject)) EditorState.MarkDirty(); }
    private void Redo() { if (TileMap.Redo(EditorState.CurrentProject)) EditorState.MarkDirty(); }

    private void CreateMap()
    {
        var id = $"map-{EditorState.CurrentProject.Maps.Count + 1}";
        var map = NewBlankMap(id, "New Map", 16, 12);
        EditorState.CurrentProject.Maps.Add(map);
        EditorState.ActiveMapId = id;
        EditorState.ToolState.ActiveLayerId = map.Layers.First().Id;
        EditorState.MarkDirty();
    }

    private void DuplicateMap()
    {
        if (ActiveMap is null) return;
        var clone = NewBlankMap($"{ActiveMap.Id}-copy-{EditorState.CurrentProject.Maps.Count}", $"{ActiveMap.Name} Copy", ActiveMap.Width, ActiveMap.Height);
        clone.MusicCue = ActiveMap.MusicCue;
        clone.Layers = ActiveMap.Layers.Select(layer => new MapLayerDefinition
        {
            Id = $"{layer.Id}-{clone.Id}", Name = layer.Name, Kind = layer.Kind, IsVisible = layer.IsVisible, IsLocked = layer.IsLocked,
            Tiles = layer.Tiles.Select(tile => new TilePlacement { X = tile.X, Y = tile.Y, TileId = tile.TileId }).ToList()
        }).ToList();
        EditorState.CurrentProject.Maps.Add(clone);
        EditorState.ActiveMapId = clone.Id;
        EditorState.ToolState.ActiveLayerId = clone.Layers.First().Id;
        EditorState.MarkDirty();
    }

    private void RenameMap() { if (ActiveMap is not null) { ActiveMap.Name = $"{ActiveMap.Name}*"; EditorState.MarkDirty(); } }
    private void ResizeMap() { if (ActiveMap is not null) { ActiveMap.Width += 2; ActiveMap.Height += 1; TrimOutOfBounds(ActiveMap); EditorState.MarkDirty(); } }
    private void DeleteMap() { if (ActiveMap is not null && EditorState.CurrentProject.Maps.Count > 1) { EditorState.CurrentProject.Maps.Remove(ActiveMap); EditorState.ActiveMapId = EditorState.CurrentProject.Maps.First().Id; EditorState.MarkDirty(); } }
    private void RenameFromInput(ChangeEventArgs args) { if (ActiveMap is not null) { ActiveMap.Name = args.Value?.ToString() ?? ActiveMap.Name; EditorState.MarkDirty(); } }
    private void UpdateMusic(ChangeEventArgs args) { if (ActiveMap is not null) { ActiveMap.MusicCue = args.Value?.ToString() ?? string.Empty; EditorState.MarkDirty(); } }
    private void ToggleVisible(MapLayerDefinition layer, ChangeEventArgs args) { layer.IsVisible = args.Value is true; EditorState.MarkDirty(); }
    private void ToggleLocked(MapLayerDefinition layer, ChangeEventArgs args) { layer.IsLocked = args.Value is true; EditorState.MarkDirty(); }

    private MapDefinition NewBlankMap(string id, string name, int width, int height) => new()
    {
        Id = id, Name = name, Width = width, Height = height, TileSetId = EditorState.CurrentProject.TileSets.First().Id,
        Layers = Enum.GetValues<MapLayerKind>().Select(kind => new MapLayerDefinition { Id = $"layer-{kind.ToString().ToLowerInvariant()}-{id}", Name = kind.ToString(), Kind = kind }).ToList()
    };

    private static void TrimOutOfBounds(MapDefinition map)
    {
        foreach (var layer in map.Layers)
        {
            layer.Tiles.RemoveAll(tile => !TileMapService.IsInBounds(map, tile.X, tile.Y));
        }
    }
}
