<div class="combatant-card">
    <div class="battle-sprite">@Combatant.Name[0]</div>
    <h3>@Combatant.Name</h3>
    <meter min="0" max="@Combatant.MaxHitPoints" value="@Combatant.HitPoints"></meter>
    <small>HP @Combatant.HitPoints/@Combatant.MaxHitPoints · MP @Combatant.MagicPoints/@Combatant.MaxMagicPoints</small>
</div>

@code {
    [Parameter, EditorRequired]
    public Combatant Combatant { get; set; } = default!;
}
