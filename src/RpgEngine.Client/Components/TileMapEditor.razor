@inject GameState State
@inject EngineCatalog Catalog

<section class="panel editor-grid-panel">
    <div class="toolbar">
        <label>Tool
            <select @bind="State.ActiveTool">
                @foreach (var tool in Enum.GetValues<EditorTool>())
                {
                    <option value="@tool">@tool</option>
                }
            </select>
        </label>
        <label>Layer
            <select @bind="State.ActiveLayer">
                @foreach (var layer in Enum.GetValues<TileLayer>())
                {
                    <option value="@layer">@layer</option>
                }
            </select>
        </label>
        <label>Tile
            <select @bind="State.SelectedTileId">
                @foreach (var tile in Catalog.Tiles)
                {
                    <option value="@tile.Id">@tile.Name</option>
                }
            </select>
        </label>
    </div>

    <div class="tile-map" style="--map-width:@GameState.MapWidth">
        @for (var y = 0; y < GameState.MapHeight; y++)
        {
            @for (var x = 0; x < GameState.MapWidth; x++)
            {
                var cell = State.Cells.LastOrDefault(tile => tile.X == x && tile.Y == y);
                var tile = Catalog.Tiles.FirstOrDefault(tile => tile.Id == cell?.TileId);
                <button class="tile tile-@(cell?.TileId ?? 0)" title="@($"{x},{y} {tile?.Name ?? "Empty"}")" @onclick="() => PaintCell(x, y)">
                    <span>@TileInitial(tile)</span>
                </button>
            }
        }
    </div>
</section>

@code {
    private void PaintCell(int x, int y) => State.Paint(x, y);

    private static string TileInitial(TileDefinition? tile) => tile is null ? string.Empty : tile.Name[..1];
}
